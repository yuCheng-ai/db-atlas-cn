---
import { BASE, SITE_TITLE, withBase } from "../consts";

const currentPath = Astro.url.pathname;

const navItems = [
  { href: BASE, label: "首页" },
  { href: withBase("flows/"), label: "选型流程" },
  { href: withBase("playbooks/"), label: "项目手册" },
  { href: withBase("stacks/"), label: "组合方案" },
  { href: withBase("databases/"), label: "数据库" },
  { href: withBase("matrix/"), label: "比较矩阵" },
  { href: withBase("glossary/"), label: "术语表" },
  { href: withBase("learning-path/"), label: "学习路径" },
];

function isActive(href: string): boolean {
  return currentPath === href || (href !== BASE && currentPath.startsWith(href));
}
---
<nav class="nav">
  <div class="nav-inner">
    <a href={BASE} class="nav-logo">
      <span class="nav-logo-icon">🗺️</span>
      {SITE_TITLE}
    </a>
    <ul class="nav-links">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class={isActive(item.href) ? "active" : ""}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
