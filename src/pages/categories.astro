---
import BaseLayout from "../layouts/BaseLayout.astro";
import { categories } from "../data/categories";
import { databases } from "../data/databases";
import { withBase } from "../consts";
---

<BaseLayout title="数据库分类说明" description="了解关系型、文档、向量、图、时序等不同类型数据库的特点和适用场景">
  <section class="hero" style="padding-bottom: var(--space-xl);">
    <h1 class="hero-title" style="font-size: 2rem;">数据库分类说明</h1>
    <p class="hero-subtitle">
      理解不同类型数据库的设计理念、核心能力和适用边界
    </p>
  </section>

  <div style="max-width: var(--content-width); margin: 0 auto; padding: 0 var(--space-lg) var(--space-2xl);">
    {categories.map((cat) => {
      const dbs = databases.filter((d) => d.categories.includes(cat.slug));
      return (
        <section id={cat.slug} style="margin-bottom: var(--space-2xl); padding-top: var(--space-lg); border-top: 1px solid var(--c-border);">
          <h2 style="font-size: 1.3rem; font-weight: 700; margin-bottom: var(--space-sm);">
            {cat.name}
          </h2>
          <p style="color: var(--c-text-secondary); line-height: 1.8; margin-bottom: var(--space-md);">
            {cat.description}
          </p>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); margin-bottom: var(--space-lg);">
            <div style="background: #dcfce7; border-radius: var(--radius); padding: var(--space-md); font-size: 0.9rem;">
              <strong style="color: #166534;">✅ 适合场景</strong>
              <p style="color: #166534; margin-top: 4px;">{cat.whenToUse}</p>
            </div>
            <div style="background: #fee2e2; border-radius: var(--radius); padding: var(--space-md); font-size: 0.9rem;">
              <strong style="color: #991b1b;">❌ 不适合场景</strong>
              <p style="color: #991b1b; margin-top: 4px;">{cat.whenNotToUse}</p>
            </div>
          </div>

          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: var(--space-sm);">
            收录的数据库（{dbs.length}）
          </h3>
          <div style="display: flex; flex-wrap: wrap; gap: 8px;">
            {dbs.map((db) => (
              <a href={withBase(`databases/${db.slug}/`)} class="filter-tag" style="text-decoration: none;">
                {db.name}
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
