---
import BaseLayout from "../layouts/BaseLayout.astro";
import { decisionSignals, solutionBundles } from "../data/solutions";
import { withBase } from "../consts";
---
<BaseLayout title="选型向导" description="根据业务场景选择数据库组合">
  <section class="hero">
    <span class="kicker">Decision Engine</span>
    <h1 class="hero-title">不要先选数据库，先定义问题</h1>
    <p class="hero-subtitle">数据库没有万能答案。先确定业务、数据模型、规模和运维能力，再选择组合方案。</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href={withBase("stacks/")}>查看组合方案</a>
      <a class="btn" href={withBase("matrix/")}>比较数据库</a>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <h2 class="section-title">选型前先回答这些问题</h2>
      <div class="signal-list">
        {decisionSignals.map((s) => <div class="signal-item"><strong>{s.label}</strong><span>{s.value}</span></div>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <h2 class="section-title">快速入口</h2>
      <div class="decision-grid">
        {solutionBundles.map((s) => (
          <a class="decision-card" href={withBase(`stacks/#${s.slug}`)}>
            <h3>{s.shortTitle}</h3>
            <p>{s.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
